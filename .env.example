# Configuration de l'environnement pour VPS Monitoring

# Port du serveur (par défaut : 3000)
PORT=3000

# Configuration de la base de données (optionnelle)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe
DB_NAME=vps_monitoring

# Niveau de logging (info, warn, error)
LOG_LEVEL=info

# Authentification (obligatoire)
# Utilisateur et mot de passe pour accéder au dashboard
ADMIN_USER=admin
ADMIN_PASSWORD=changer_mot_de_passe

# Clé secrète pour les sessions (générez-en une avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=votre_cle_secrete_aleatoire_ici

# Nom du VPS (optionnel, utilisé dans les notifications)
VPS_NAME=MonVPS

# IP ou domaine du VPS (optionnel, utilisé dans les liens du dashboard)
VPS_IP=localhost

# ============================================
# Configuration optionnelle (peut aussi être configurée via l'interface)
# ============================================
# Les paramètres suivants peuvent être configurés soit via ce fichier .env,
# soit directement depuis le menu Configuration du dashboard.
# Les valeurs ici servent de valeurs par défaut.

# Configuration Telegram Bot (Notifications d'alerte)
# Activer les notifications Telegram (true/false)
TELEGRAM_ENABLED=false
# Token du bot Telegram (obtenu via @BotFather sur Telegram)
TELEGRAM_BOT_TOKEN=
# ID du chat ou groupe Telegram
TELEGRAM_CHAT_ID=
# Délai entre 2 notifications pour la même alerte (en minutes)
TELEGRAM_COOLDOWN_MINUTES=15
# Envoyer une notification quand l'alerte est résolue (true/false)
TELEGRAM_NOTIFY_RESOLUTION=true
